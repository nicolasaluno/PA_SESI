<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quiz Game 🎮</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gradient-to-r from-indigo-600 to-purple-700 min-h-screen flex items-center justify-center text-white">

  <div class="bg-white text-gray-800 p-8 rounded-2xl shadow-2xl w-[90%] max-w-xl text-center">
    <h1 class="text-3xl font-bold mb-4">Quiz Game 🎯</h1>
    <p id="nivel" class="mb-2 font-semibold"></p>
    <p id="pergunta" class="text-lg mb-6"></p>

    <div id="respostas" class="grid gap-3"></div>

    <p id="resultado" class="mt-6 font-bold"></p>
    <button onclick="proximaPergunta()" id="btnProximo" class="mt-4 hidden bg-indigo-600 text-white px-5 py-2 rounded-xl">Próxima</button>
  </div>

  <script>
    const perguntas = [
      // Nível Fácil
      {
        nivel: "Fácil",
        pergunta: "Qual é a capital do Brasil?",
        respostas: ["São Paulo", "Brasília", "Rio de Janeiro", "Curitiba"],
        correta: 1
      },
      {
        nivel: "Fácil",
        pergunta: "Quanto é 2 + 2?",
        respostas: ["3", "4", "5", "6"],
        correta: 1
      },

      // Médio
      {
        nivel: "Médio",
        pergunta: "Quem descobriu o Brasil?",
        respostas: ["Dom Pedro", "Cabral", "Colombo", "Neymar"],
        correta: 1
      },
      {
        nivel: "Médio",
        pergunta: "Quanto é 5 x 6?",
        respostas: ["11", "25", "30", "60"],
        correta: 2
      },

      // Difícil
      {
        nivel: "Difícil",
        pergunta: "Qual é o maior planeta do sistema solar?",
        respostas: ["Terra", "Marte", "Júpiter", "Saturno"],
        correta: 2
      },
      {
        nivel: "Difícil",
        pergunta: "Quanto é 12²?",
        respostas: ["124", "144", "132", "154"],
        correta: 1
      }
    ];

    let atual = 0;
    let pontos = 0;

    function carregarPergunta() {
      const q = perguntas[atual];
      document.getElementById("nivel").innerText = "Nível: " + q.nivel;
      document.getElementById("pergunta").innerText = q.pergunta;
      document.getElementById("resultado").innerText = "";
      document.getElementById("btnProximo").classList.add("hidden");

      const respostasDiv = document.getElementById("respostas");
      respostasDiv.innerHTML = "";

      q.respostas.forEach((resposta, index) => {
        const btn = document.createElement("button");
        btn.innerText = resposta;
        btn.className = "bg-gray-200 p-3 rounded-xl hover:bg-gray-300";
        btn.onclick = () => verificarResposta(index);
        respostasDiv.appendChild(btn);
      });
    }

    function verificarResposta(index) {
      const correta = perguntas[atual].correta;

      if (index === correta) {
        document.getElementById("resultado").innerText = "Correto! ✅";
        pontos++;
      } else {
        document.getElementById("resultado").innerText = "Errado ❌";
      }

      document.getElementById("btnProximo").classList.remove("hidden");
    }

    function proximaPergunta() {
      atual++;

      if (atual < perguntas.length) {
        carregarPergunta();
      } else {
        document.querySelector(".bg-white").innerHTML = `
          <h1 class="text-3xl font-bold mb-4">Fim de Jogo 🎉</h1>
          <p class="text-xl">Sua pontuação: ${pontos}/${perguntas.length}</p>
          <button onclick="location.reload()" class="mt-4 bg-indigo-600 text-white px-5 py-2 rounded-xl">Jogar novamente</button>
        `;
      }
    }

    carregarPergunta();
  </script>

</body>
</html>
