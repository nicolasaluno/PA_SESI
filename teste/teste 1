<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Loja StreetWear 🔥</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 text-gray-800">

  <!-- HEADER -->
  <header class="bg-black text-white p-5 flex justify-between items-center">
    <h1 class="text-2xl font-bold">StreetWear</h1>
    <nav class="space-x-4">
      <a href="#" class="hover:text-gray-400">Início</a>
      <a href="#produtos" class="hover:text-gray-400">Produtos</a>
      <a href="#contato" class="hover:text-gray-400">Contato</a>
    </nav>
  </header>

  <!-- HERO -->
  <section class="text-center py-16 bg-gradient-to-r from-black to-gray-700 text-white">
    <h2 class="text-4xl font-bold mb-4">Nova Coleção 2026</h2>
    <p class="mb-6">Estilo, atitude e conforto em um só lugar</p>
    <button class="bg-white text-black px-6 py-3 rounded-xl font-semibold hover:scale-110 transition">
      Ver Produtos
    </button>
  </section>

  <!-- PRODUTOS -->
  <section id="produtos" class="py-12 px-6">
    <h2 class="text-3xl font-bold text-center mb-10">Produtos 🔥</h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

      <!-- Produto 1 -->
      <div class="bg-white rounded-2xl shadow-lg p-4 text-center">
        <img src="https://via.placeholder.com/300" class="rounded-xl mb-4">
        <h3 class="text-xl font-semibold">Camiseta Oversized</h3>
        <p class="text-gray-600">R$ 79,90</p>
        <button onclick="comprar('Camiseta Oversized')" class="mt-3 bg-black text-white px-4 py-2 rounded-xl hover:bg-gray-800">Comprar</button>
      </div>

      <!-- Produto 2 -->
      <div class="bg-white rounded-2xl shadow-lg p-4 text-center">
        <img src="https://via.placeholder.com/300" class="rounded-xl mb-4">
        <h3 class="text-xl font-semibold">Moletom Premium</h3>
        <p class="text-gray-600">R$ 149,90</p>
        <button onclick="comprar('Moletom Premium')" class="mt-3 bg-black text-white px-4 py-2 rounded-xl hover:bg-gray-800">Comprar</button>
      </div>

      <!-- Produto 3 -->
      <div class="bg-white rounded-2xl shadow-lg p-4 text-center">
        <img src="https://via.placeholder.com/300" class="rounded-xl mb-4">
        <h3 class="text-xl font-semibold">Boné Street</h3>
        <p class="text-gray-600">R$ 49,90</p>
        <button onclick="comprar('Boné Street')" class="mt-3 bg-black text-white px-4 py-2 rounded-xl hover:bg-gray-800">Comprar</button>
      </div>

    </div>
  </section>

  <!-- CONTATO -->
  <section id="contato" class="bg-gray-200 py-12 text-center">
    <h2 class="text-2xl font-bold mb-4">Fale com a gente 📩</h2>
    <p>Email: contato@streetwear.com</p>
    <p>Instagram: @streetwear</p>
  </section>

  <!-- FOOTER -->
  <footer class="bg-black text-white text-center p-4">
    © 2026 StreetWear - Todos os direitos reservados
  </footer>

  <!-- SCRIPT -->
  <script>
    function comprar(produto) {
      alert("Você adicionou " + produto + " ao carrinho 🛒");
    }
  </script>

</body>
</html>